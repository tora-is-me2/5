-- DRAGGING LOGIC
local dragging = false
local dragInput, dragStart, startPos

local function update(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

HeaderBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

HeaderBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then update(input) end
end)

-- LOOP LOGIC
local winActive = false
local rebirthActive = false
local winConn = nil

-- Auto Win (Fast RenderStepped)
local function startWin()
    if winConn then winConn:Disconnect() end
    winConn = RunService.RenderStepped:Connect(function()
        if Character and HumanoidRootPart and targetPart then
            HumanoidRootPart.CFrame = targetPart.CFrame * CFrame.new(0, 0.5, 0)
        end
    end)
end

-- Auto Rebirth
local function startRebirth()
    spawn(function()
        while rebirthActive do
            if rebirthRemote then
                rebirthRemote:FireServer()
                StatusLabel.Text = "Rebirth Fired!"
            end
            task.wait(REBIRTH_DELAY)
            if not rebirthActive then break end
        end
    end)
end

-- BUTTON ACTIONS
WinButton.MouseButton1Click:Connect(function()
    winActive = not winActive
    if winActive then
        if not targetPart then
            StatusLabel.Text = "Error: Win Model Not Found!"
            winActive = false
            return
        end
        WinButton.Text = "■ Stop Auto Win"
        WinButton.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
        StatusLabel.Text = "Auto Win: ON (Max Speed)"
        startWin()
    else
        WinButton.Text = "▶ Start Auto Win"
        WinButton.BackgroundColor3 = Color3.fromRGB(0, 140, 0)
        if not rebirthActive then StatusLabel.Text = "Ready" else StatusLabel.Text = "Rebirth: ON" end
        if winConn then winConn:Disconnect() end
    end
end)

RebirthButton.MouseButton1Click:Connect(function()
    rebirthActive = not rebirthActive
    if rebirthActive then
        if not rebirthRemote then
            StatusLabel.Text = "Error: Rebirth Remote Missing!"
            rebirthActive = false
            return
        end
        RebirthButton.Text = "■ Stop Auto Rebirth"
        RebirthButton.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
        StatusLabel.Text = "Auto Rebirth: ON"
        startRebirth()
    else
        RebirthButton.Text = "▶ Start Auto Rebirth"
        RebirthButton.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
        if not winActive then StatusLabel.Text = "Ready" else StatusLabel.Text = "Auto Win: ON" end
    end
end)

