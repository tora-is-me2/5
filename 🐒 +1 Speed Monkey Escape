local REBIRTH_DELAY = 1.5 -- Seconds between rebirths (lower = faster, but might kick)

-- 1. AUTO WIN TARGET
local modelPath = {"World2", "Stage4", "NormalWin"}
local targetModel = workspace
for _, name in ipairs(modelPath) do
    targetModel = targetModel:FindFirstChild(name)
    if not targetModel then break end
end

local function getTargetPart(model)
    if not model then return nil end
    if model.PrimaryPart then return model.PrimaryPart end
    for _, child in pairs(model:GetChildren()) do
        if child:IsA("BasePart") then return child end
    end
    return nil
end

local targetPart = getTargetPart(targetModel)

